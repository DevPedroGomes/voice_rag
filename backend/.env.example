# OpenAI
OPENAI_API_KEY=your-openai-api-key

# PostgreSQL with pgvector
# Local: postgresql://postgres:postgres@localhost:5432/voicerag
# Railway: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voicerag

# Session - inactivity-based cleanup
SESSION_INACTIVITY_MINUTES=5   # Sessions expire after 5 min of inactivity
CLEANUP_INTERVAL_MINUTES=1     # Check for expired sessions every 1 min

# CORS - Add your frontend URL for production
# For Railway: ["http://localhost:3000","https://your-frontend.railway.app"]
CORS_ORIGINS=["http://localhost:3000"]

# File Upload
MAX_FILE_SIZE_MB=10

# Rate Limiting (showcase protection)
MAX_QUERIES_PER_SESSION=5
MAX_DOCUMENTS_PER_SESSION=3
MAX_SESSIONS_PER_MINUTE=10

# AI Models
PROCESSOR_MODEL=gpt-4.1-mini
TTS_MODEL=gpt-4o-mini-tts
